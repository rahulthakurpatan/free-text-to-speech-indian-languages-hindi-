                if (saved) { setApiKey(saved); setIsConfigured(true); }
                if(window.lucide) window.lucide.createIcons();
            }, []);

            const voices = [
                { id: 'Charon', name: 'Arjun', desc: 'Bold Narrator', gender: 'M' },
                { id: 'Leda', name: 'Priya', desc: 'Warm Story', gender: 'F' },
                { id: 'Aoede', name: 'Anjali', desc: 'Soft Narrative', gender: 'F' },
                { id: 'Kore', name: 'Amit', desc: 'Confident', gender: 'M' },
                { id: 'Enceladus', name: 'Sagar', desc: 'High Energy', gender: 'M' },
                { id: 'Fenrir', name: 'Rahul', desc: 'Smooth Male', gender: 'M' },
                { id: 'Callirrhoe', name: 'Kavita', desc: 'Mature/Deep', gender: 'F' },
                { id: 'Iapetus', name: 'George', desc: 'Classic Pro', gender: 'M' }
            ];

            const pcmToWav = (b64) => {
                const bin = atob(b64);
                const bytes = new Uint8Array(bin.length);
                for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
                const pcm = new Int16Array(bytes.buffer);
                const buffer = new ArrayBuffer(44 + pcm.length * 2);
                const view = new DataView(buffer);
                const s = (o, str) => { for (let i = 0; i < str.length; i++) view.setUint8(o + i, str.charCodeAt(i)); };
                s(0, 'RIFF'); view.setUint32(4, 36 + pcm.length * 2, true); s(8, 'WAVE'); s(12, 'fmt ');
                view.setUint32(16, 16, true); view.setUint16(20, 1, true); view.setUint16(22, 1, true);
                view.setUint32(24, 24000, true); view.setUint32(28, 48000, true); view.setUint16(32, 2, true);
                view.setUint16(34, 16, true); s(36, 'data'); view.setUint32(40, pcm.length * 2, true);
                for (let i = 0; i < pcm.length; i++) view.setInt16(44 + i * 2, pcm[i], true);
                return new Blob([buffer], { type: 'audio/wav' });
            };

            const generateAudio = async () => {
                if (!text.trim()) return;
                setIsGenerating(true); setError(null); setAudioUrl(null);
                try {
                    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            contents: [{ parts: [{ text: text }] }],
                            generationConfig: {
                                responseModalities: ["AUDIO"],
                                speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: voiceProfile } } }
                            }
                        })
                    });
                    const data = await response.json();
                    const b64 = data.candidates?.[0]?.content?.parts?.find(p => p.inlineData)?.inlineData?.data;
                    if (!b64) throw new Error("API Key Error or Limit Reached.");
                    const url = URL.createObjectURL(pcmToWav(b64));
                    setAudioUrl(url);
                } catch (err) { setError(err.message); } finally { setIsGenerating(false); }
            };

            return (
                <div className="max-w-7xl mx-auto px-4 text-left">
                    {!isConfigured ? (
                        <div className="glass-card p-10 md:p-20 border-2 border-orange-100 flex flex-col md:flex-row gap-16 items-center text-left">
                            <div className="flex-1 text-left">
                                <span className="bg-orange-50 text-orange-600 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest mb-6 inline-block">YouTube Monetization Hub</span>
                                <h2 className="text-4xl md:text-6xl font-black mb-10 italic uppercase text-blue-800 leading-[1.1] tracking-tighter text-left">Unlock AI Earning <br/> Potential</h2>
                                <div className="space-y-6 mb-12 text-left">
                                    <div className="flex gap-4 items-start text-left"><div className="w-9 h-9 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shrink-0 shadow-lg text-center">1</div><p className="text-sm font-bold text-slate-400 mt-1">Get your free key from Google AI Studio.</p></div>
                                    <div className="flex gap-4 items-start text-left"><div className="w-9 h-9 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shrink-0 shadow-lg text-center">2</div><p className="text-sm font-bold text-slate-400 mt-1 text-left">Paste it here to unlock 20+ viral voices.</p></div>
                                    <div className="flex gap-4 items-start text-left"><div className="w-9 h-9 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shrink-0 shadow-lg text-center text-center">3</div><p className="text-sm font-bold text-slate-400 mt-1 text-left">Scale your YouTube income for zero cost.</p></div>
                                </div>
                                <a href="https://aistudio.google.com/app/apikey" target="_blank" className="bg-white border-2 border-orange-500 text-orange-600 px-10 py-5 rounded-[2rem] font-black text-xs uppercase hover:bg-orange-50 transition-all inline-flex items-center gap-4 shadow-2xl"><Icon name="key" size={18}/> Get Free Gemini API Key</a>
                            </div>
                            <div className="w-full max-w-sm glass-card p-12 border-slate-900 shadow-2xl relative text-center">
                                <Icon name="shield-check" size={48} className="text-blue-600 mb-8 mx-auto" />
                                <h3 className="text-xs font-black uppercase text-center mb-10 tracking-[0.3em] text-slate-400 italic text-center">Activation Hub</h3>
                                <input type="password" value={apiKey} onChange={(e) => setApiKey(e.target.value)} placeholder="Paste AIza Key" className="w-full p-6 rounded-[2rem] border-2 border-slate-200 bg-slate-50 mb-8 text-center font-mono text-xl outline-none focus:border-blue-600 transition-all" />
                                <button onClick={() => { if(apiKey.length > 20) { localStorage.setItem('vani_v5_key', apiKey); setIsConfigured(true); }}} className="w-full py-7 bg-orange-600 text-white rounded-[2.5rem] font-black text-2xl shadow-2xl hover:bg-orange-700 active:scale-95 transition-all uppercase tracking-tighter">Enter Studio</button>
                            </div>
                        </div>
                    ) : (
                        <div className="grid grid-cols-1 lg:grid-cols-12 gap-8 text-left text-left">
                            <div className="lg:col-span-8 space-y-6 text-left">
                                <textarea value={text} onChange={(e) => setText(e.target.value)} className="w-full h-80 p-8 rounded-[2.5rem] border-2 border-slate-100 bg-white text-2xl font-bold text-slate-900 outline-none focus:border-orange-400 transition-all resize-none shadow-inner custom-scrollbar text-left" />
                                <div className="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-4 gap-3 text-left">
                                    {voices.map(v => (
                                        <button key={v.id} onClick={() => setVoiceProfile(v.id)} className={`voice-grid-btn ${voiceProfile === v.id ? 'active border-orange-500 shadow-inner' : 'hover:border-slate-300'}`}>
                                            <div className="flex justify-between items-start mb-1 text-left"><p className={`text-[11px] font-black uppercase ${voiceProfile === v.id ? 'text-orange-600' : 'text-slate-800'}`}>{v.name}</p><span className={`text-[7px] font-bold px-1 rounded ${v.gender === 'M' ? 'bg-blue-100 text-blue-700' : 'bg-pink-100 text-pink-700'}`}>{v.gender}</span></div>
                                            <p className="text-[8px] font-bold text-slate-400 leading-tight uppercase italic text-left">{v.desc}</p>
                                        </button>
                                    ))}
                                </div>
                                <button onClick={generateAudio} disabled={isGenerating || !text.trim()} className="w-full py-10 bg-blue-800 text-white rounded-[3rem] text-3xl font-black shadow-2xl hover:bg-blue-900 transition-all flex items-center justify-center gap-6">
                                    {isGenerating ? <div className="custom-loader" style={{width: 32, height: 32}}></div> : <Icon name="zap" size={32} className="text-orange-400" />}
                                    {isGenerating ? "GENERATING VOICE..." : "GENERATE AI VOICE"}
                                </button>
                                {error && <div className="p-4 bg-red-50 text-red-700 rounded-2xl border border-red-100 text-xs font-black text-left">{error}</div>}
                            </div>
                            <div className="lg:col-span-4 text-left">
                                <div className="p-10 border-2 border-dashed border-slate-200 rounded-[4rem] text-center min-h-[500px] flex flex-col justify-center sticky top-28 bg-white/50 backdrop-blur-sm shadow-xl text-center">
                                    <h3 className="text-[10px] font-black uppercase mb-12 italic tracking-[0.2em] text-slate-400 border-b pb-6 text-center text-center">Studio Output</h3>
                                    {!audioUrl ? (<div className="opacity-20 flex flex-col items-center text-center text-center"><Icon name="music" size={72} className="mb-6 text-center"/><p className="text-[11px] font-black uppercase tracking-widest text-center text-center">Script Required</p></div>) : (
                                        <div className="space-y-12 animate-up text-center">
                                            <div className="p-8 bg-blue-50/50 rounded-[3rem] border border-blue-100 shadow-inner text-center text-center"><audio src={audioUrl} controls className="w-full" autoPlay /></div>
                                            <a href={audioUrl} download="Vani_Monetization_Audio.wav" className="w-full py-6 bg-white border-2 border-blue-800 text-blue-800 rounded-[2rem] font-black uppercase flex items-center justify-center gap-3 hover:bg-blue-50 transition-all text-center">Download WAV</a>
                                        </div>
                                    )}
                                    <button onClick={() => {localStorage.removeItem('vani_v5_key'); setIsConfigured(false);}} className="w-full mt-20 py-4 text-[11px] font-black uppercase text-slate-400 hover:text-red-600 border border-slate-100 rounded-2xl transition-all text-center">Reset Studio Key</button>
                                </div>
                            </div>
                        </div>
                    )}
                </div>
            );
        };
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
    <script>lucide.createIcons();</script>
</body>
</html>
