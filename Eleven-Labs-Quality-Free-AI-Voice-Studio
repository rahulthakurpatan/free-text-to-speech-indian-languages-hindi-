    <!-- REACT LOGIC SCRIPT (The Premium Studio) -->
    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        const Icon = ({ name, className = "w-5 h-5", size = 20 }) => {
            const iconRef = useRef(null);
            useEffect(() => {
                if (window.lucide && iconRef.current) {
                    iconRef.current.innerHTML = `<i data-lucide="${name}" style="width:${size}px; height:${size}px"></i>`;
                    window.lucide.createIcons({ root: iconRef.current });
                }
            }, [name, size]);
            return <span ref={iconRef} className={`inline-flex items-center justify-center ${className}`}></span>;
        };

        const App = () => {
            const [isConfigured, setIsConfigured] = useState(false);
            const [apiKey, setApiKey] = useState('');
            const [text, setText] = useState('नमस्ते, आपका स्वागत है वाणी एआई स्टूडियो में। अब आप एडम और नताशा जैसी प्रीमियम आवाज़ों का आनंद बिल्कुल मुफ्त में ले सकते हैं।');
            const [voiceProfile, setVoiceProfile] = useState('Charon');
            const [audioUrl, setAudioUrl] = useState(null);
            const [isGenerating, setIsGenerating] = useState(false);
            const [error, setError] = useState(null);
            const audioRef = useRef(null);

            useEffect(() => {
                const saved = localStorage.getItem('vani_v5_key');
                if (saved) { setApiKey(saved); setIsConfigured(true); }
                if(window.lucide) window.lucide.createIcons();
            }, []);

            // Mapped Eleven Labs Style Personas
            const voices = [
                { id: 'Kore', name: 'Natasha', desc: 'High Energy "Valley Girl"', gender: 'F' },
                { id: 'Charon', name: 'Adam', desc: 'Deep, Narrative & Stable', gender: 'M' },
                { id: 'Orus', name: 'Josh', desc: 'Clear, Authoritative', gender: 'M' },
                { id: 'Aoede', name: 'Bella', desc: 'Soft, Calm, Pleasant', gender: 'F' },
                { id: 'Enceladus', name: 'Aaron', desc: 'Tech-focused & Energetic', gender: 'M' },
                { id: 'Zephyr', name: 'David', desc: 'British Storyteller', gender: 'M' },
                { id: 'Leda', name: 'Cassidy', desc: 'Warm & Conversational', gender: 'F' },
                { id: 'Fenrir', name: 'Bill L. Oxley', desc: 'Rich, Distinguished', gender: 'M' },
                { id: 'Callirrhoe', name: 'Michael C.', desc: 'Thriller & Mystery', gender: 'F' },
                { id: 'Autonoe', name: 'Erin', desc: 'Soothing & Meditative', gender: 'F' }
            ];

            const pcmToWav = (b64) => {
                const bin = atob(b64);
                const bytes = new Uint8Array(bin.length);
                for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
                const pcm = new Int16Array(bytes.buffer);
                const buffer = new ArrayBuffer(44 + pcm.length * 2);
                const view = new DataView(buffer);
                const s = (o, str) => { for (let i = 0; i < str.length; i++) view.setUint8(o + i, str.charCodeAt(i)); };
                s(0, 'RIFF'); view.setUint32(4, 36 + pcm.length * 2, true); s(8, 'WAVE'); s(12, 'fmt ');
                view.setUint32(16, 16, true); view.setUint16(20, 1, true); view.setUint16(22, 1, true);
                view.setUint32(24, 24000, true); view.setUint32(28, 48000, true); view.setUint16(32, 2, true);
                view.setUint16(34, 16, true); s(36, 'data'); view.setUint32(40, pcm.length * 2, true);
                for (let i = 0; i < pcm.length; i++) view.setInt16(44 + i * 2, pcm[i], true);
                return new Blob([buffer], { type: 'audio/wav' });
            };

            const generateAudio = async () => {
                if (!text.trim()) return;
                setIsGenerating(true); setError(null); setAudioUrl(null);
                try {
                    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            contents: [{ parts: [{ text: text }] }],
                            generationConfig: {
                                responseModalities: ["AUDIO"],
                                speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: voiceProfile } } }
                            }
                        })
                    });
                    if (response.status === 429) throw new Error("Free Limit Reached. Wait 1 min.");
                    const data = await response.json();
                    const b64 = data.candidates?.[0]?.content?.parts?.find(p => p.inlineData)?.inlineData?.data;
                    if (!b64) throw new Error("Invalid Response or API Key.");
                    const url = URL.createObjectURL(pcmToWav(b64));
                    setAudioUrl(url);
                } catch (err) { setError(err.message); } finally { setIsGenerating(false); }
            };

            return (
                <div className="max-w-7xl mx-auto px-4">
                    {!isConfigured ? (
                        <div className="glass-card p-10 md:p-20 border-2 border-orange-100 flex flex-col md:flex-row gap-16 items-center">
                            <div className="flex-1 text-left text-left">
                                <span className="bg-orange-50 text-orange-600 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest mb-6 inline-block">Persona Activation</span>
                                <h2 className="text-4xl md:text-6xl font-black mb-10 italic uppercase text-blue-800 leading-[1.1] tracking-tighter">Unlock Adam & <br/> Natasha Voices</h2>
                                <div className="space-y-6 mb-12">
                                    <div className="flex gap-4 items-start text-left">
                                        <div className="w-9 h-9 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shrink-0 shadow-lg">1</div>
                                        <div>
                                           <p className="text-base font-black text-slate-800 uppercase italic leading-none">Get Free API Key</p>
                                           <p className="text-xs font-bold text-slate-400 mt-1">Visit Google AI Studio and generate your free personal API key.</p>
                                        </div>
                                    </div>
                                    <div className="flex gap-4 items-start text-left">
                                        <div className="w-9 h-9 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shrink-0 shadow-lg">2</div>
                                        <div>
                                           <p className="text-base font-black text-slate-800 uppercase italic leading-none">Paste & Activate</p>
                                           <p className="text-xs font-bold text-slate-400 mt-1">Enter the key in the secure activation box below.</p>
                                        </div>
                                    </div>
                                    <div className="flex gap-4 items-start text-left">
                                        <div className="w-9 h-9 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shrink-0 shadow-lg">3</div>
                                        <div>
                                           <p className="text-base font-black text-slate-800 uppercase italic leading-none">Start Production</p>
                                           <p className="text-xs font-bold text-slate-400 mt-1">Generate premium narrations instantly for free.</p>
                                        </div>
                                    </div>
                                </div>
                                <a href="https://aistudio.google.com/app/apikey" target="_blank" className="bg-white border-2 border-orange-500 text-orange-600 px-10 py-5 rounded-[2rem] font-black text-xs uppercase hover:bg-orange-50 transition-all inline-flex items-center gap-4 shadow-2xl">
                                    <Icon name="key" size={18}/> Get Free Gemini API Key
                                </a>
                            </div>
                            <div className="w-full max-w-sm glass-card p-12 border-slate-900 shadow-2xl relative text-center">
                                <div className="absolute -top-6 left-1/2 -translate-x-1/2 bg-blue-800 text-white px-6 py-2 rounded-full text-[10px] font-black uppercase tracking-[0.2em] shadow-xl">Master Hub</div>
                                <Icon name="shield-check" size={48} className="text-blue-600 mb-8 mx-auto" />
                                <h3 className="text-xs font-black uppercase text-center mb-10 tracking-[0.3em] text-slate-400 italic italic">Activation Box</h3>
                                <input type="password" value={apiKey} onChange={(e) => setApiKey(e.target.value)} placeholder="AIzaSy... Key Here" class="w-full p-6 rounded-[2rem] border-2 border-slate-200 bg-slate-50 mb-8 text-center font-mono text-xl outline-none focus:border-blue-600 transition-all" />
                                <button onClick={() => { if(apiKey.length > 20) { localStorage.setItem('vani_v5_key', apiKey); setIsConfigured(true); }}} className="w-full py-7 bg-orange-600 text-white rounded-[2.5rem] font-black text-2xl shadow-2xl hover:bg-orange-700 active:scale-95 transition-all uppercase tracking-tighter">Open Vāṇī Studio</button>
                                <p className="mt-8 text-[10px] font-bold text-slate-400 text-center uppercase tracking-tight">Your key stays 100% private in your browser storage.</p>
                            </div>
                        </div>
                    ) : (
                        <div className="grid grid-cols-1 lg:grid-cols-12 gap-10">
                            <div className="lg:col-span-8 space-y-8 text-left text-left">
                                <div className="glass-card p-12 border-slate-900 shadow-2xl relative">
                                    <div className="flex justify-between items-center mb-10 border-b border-slate-100 pb-6 text-left">
                                        <h3 className="text-[12px] font-black uppercase text-blue-700 tracking-[0.3em] flex items-center gap-4 text-left">
                                            <Icon name="file-text" size={20} /> Neural Script Editor
                                        </h3>
                                        <button onClick={() => setText('')} className="text-slate-300 hover:text-red-500 transition-all active:scale-90"><Icon name="trash-2" size={20} /></button>
                                    </div>
                                    <textarea value={text} onChange={(e) => setText(e.target.value)} className="w-full h-80 bg-transparent border-none outline-none text-2xl font-bold text-slate-900 resize-none leading-relaxed custom-scrollbar text-left" />
                                </div>
                                
                                {/* Premium Voice Grid */}
                                <div className="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
                                    {voices.map(v => (
                                        <button key={v.id} onClick={() => setVoiceProfile(v.id)} className={`voice-btn ${voiceProfile === v.id ? 'active shadow-inner' : 'bg-slate-50 hover:border-blue-300'}`}>
                                            <div className="flex justify-between items-start mb-1 text-left">
                                                <p className={`text-[12px] font-black uppercase ${voiceProfile === v.id ? 'text-orange-600' : 'text-slate-800'}`}>{v.name}</p>
                                                <span className={`text-[7px] font-bold px-1 rounded ${v.gender === 'M' ? 'bg-blue-100 text-blue-700' : 'bg-pink-100 text-pink-700'}`}>{v.gender}</span>
                                            </div>
                                            <p className="text-[8px] font-bold text-slate-400 leading-tight uppercase">{v.desc}</p>
                                        </button>
                                    ))}
                                </div>

                                <button onClick={generateAudio} disabled={isGenerating || !text.trim()} className="w-full py-12 bg-blue-800 text-white rounded-[4rem] text-4xl font-black shadow-2xl flex items-center justify-center gap-8 hover:bg-blue-900 active:scale-[0.98] transition-all group">
                                    {isGenerating ? <div className="custom-loader" style={{width: 38, height: 38}}></div> : <Icon name="sparkles" size={48} className="text-orange-400 group-hover:rotate-12 transition-transform" />}
                                    {isGenerating ? "GENERATING NARRATION..." : "GENERATE PREMIUM VOICE"}
                                </button>
                                {error && <div className="p-5 bg-red-50 text-red-700 rounded-3xl border border-red-200 text-xs font-black flex items-center gap-3 shadow-sm animate-bounce text-left"><Icon name="alert-circle" size={18} /> {error}</div>}
                            </div>
                            <div className="lg:col-span-4">
                                <div className="glass-card p-12 text-center sticky top-40 border-slate-900 shadow-2xl text-center">
                                    <h3 className="text-[12px] font-black uppercase mb-12 italic tracking-[0.2em] text-slate-400 border-b border-slate-50 pb-6 text-center">Output Studio</h3>
                                    {!audioUrl ? (
                                        <div className="py-32 border-2 border-dashed border-slate-100 rounded-[4rem] opacity-20 flex flex-col items-center text-center">
                                            <Icon name="music" size={72} className="mb-6" />
                                            <p className="text-[11px] font-black uppercase tracking-widest text-center">No Audio Generated</p>
                                        </div>
                                    ) : (
                                        <div className="space-y-12 animate-up">
                                            <div className="p-12 bg-blue-50/50 rounded-[4rem] border border-blue-100 shadow-inner relative overflow-hidden text-center text-center">
                                                <div className="flex justify-center mb-12 relative z-10">
                                                    <div className="w-20 h-20 bg-blue-600 text-white rounded-full flex items-center justify-center animate-pulse shadow-2xl shadow-blue-200">
                                                        <Icon name="play" size={32} className="fill-white ml-1" />
                                                    </div>
                                                </div>
                                                <audio ref={audioRef} src={audioUrl} controls className="w-full h-10 relative z-10" autoPlay />
                                            </div>
                                            <a href={audioUrl} download="Vani_Premium_Voice.wav" className="w-full py-7 bg-white border-2 border-blue-800 text-blue-800 rounded-[2.5rem] text-sm font-black uppercase flex items-center justify-center gap-4 hover:bg-blue-50 transition-all shadow-2xl text-center">
                                                <Icon name="download" size={24} /> Download WAV
                                            </a>
                                        </div>
                                    )}
                                    <button onClick={() => {localStorage.removeItem('vani_v5_key'); setIsConfigured(false);}} className="w-full mt-20 py-4 text-[11px] font-black uppercase text-slate-400 hover:text-red-600 border border-slate-100 rounded-2xl transition-all text-center">Reset Studio Key</button>
                                </div>
                            </div>
                        </div>
                    )}
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>

