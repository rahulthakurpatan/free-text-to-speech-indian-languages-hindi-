                                        </div>
                                    </div>
                                    <div className="flex gap-4 items-start text-left">
                                        <div className="w-9 h-9 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shrink-0 shadow-lg">2</div>
                                        <div>
                                           <p className="text-base font-black text-slate-800 uppercase italic leading-none">Paste & Activate</p>
                                           <p className="text-xs font-bold text-slate-400 mt-1">Enter the key in the secure activation box below.</p>
                                        </div>
                                    </div>
                                    <div className="flex gap-4 items-start text-left">
                                        <div className="w-9 h-9 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shrink-0 shadow-lg">3</div>
                                        <div>
                                           <p className="text-base font-black text-slate-800 uppercase italic leading-none">Start Production</p>
                                           <p className="text-xs font-bold text-slate-400 mt-1">Generate premium narrations instantly for free.</p>
                                        </div>
                                    </div>
                                </div>
                                <a href="https://aistudio.google.com/app/apikey" target="_blank" className="bg-white border-2 border-orange-500 text-orange-600 px-10 py-5 rounded-[2rem] font-black text-xs uppercase hover:bg-orange-50 transition-all inline-flex items-center gap-4 shadow-2xl">
