                            </div>
                            <div className="lg:col-span-4">
                                <div className="glass-card p-12 text-center sticky top-40 border-slate-900 shadow-2xl text-center">
                                    <h3 className="text-[12px] font-black uppercase mb-12 italic tracking-[0.2em] text-slate-400 border-b border-slate-50 pb-6 text-center text-center">Output Studio</h3>
                                    {!audioUrl ? (
